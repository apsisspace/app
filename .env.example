# Apsis Space — environment variables
#
# Copy this file to `.env.local` and fill in values as needed. `.env.local`
# is git-ignored by Vite's default template.

# Optional: Cesium ion access token for premium imagery / terrain.
# Get one free at https://ion.cesium.com/ → Access Tokens.
# If unset, Apsis Space falls back to OpenStreetMap imagery.
VITE_CESIUM_ION_TOKEN=

# Server-side only (never expose with VITE_ prefix).
# Used by the future AI query layer (Claude Haiku via Vercel Edge Function).
ANTHROPIC_API_KEY=
